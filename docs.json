          "href": "https://github.com/Arenukvern/ecsly/blob/main/ARCHITECTURE.md"
        },
        {
          "title": "API docs",
          "href": "https://pub.dev/documentation/ecsly/latest/"
        }
      ]
    },
    {
      "group": "Decisions",
      "pages": [
        {
          "title": "Overview",
          "href": "/decisions"
        }
      ]
    }
  ]
